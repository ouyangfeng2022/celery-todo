{
  "name": "celery-todo",
  "private": true,
  "version": "1.4.0",
  "description": "A full-featured Todo List application with Celery-style UI",
  "author": "",
  "license": "MIT",
  "main": "dist-electron/main.js",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/ouyangfeng2022/celery-todo.git"
  },
  "bugs": {
    "url": "https://github.com/ouyangfeng2022/celery-todo/issues"
  },
  "homepage": "https://github.com/ouyangfeng2022/celery-todo#readme",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:electron": "tsc -b && vite build && tsc -p electron/tsconfig.json && node scripts/fix-electron-cjs.mjs",
    "electron:dev": "tsc -p electron/tsconfig.json && node scripts/fix-electron-cjs.mjs && concurrently \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "bun run build && tsc -p electron/tsconfig.json && node scripts/fix-electron-cjs.mjs && electron-builder",
    "bump": "node scripts/bump-version.mjs",
    "extract-changelog": "node scripts/extract-changelog.mjs",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "electron-updater": "^6.8.9",
    "framer-motion": "^11.3.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "sql.js": "^1.11.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.9",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.0.2",
    "@vitest/ui": "^2.0.2",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.2.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.8",
    "jsdom": "^24.1.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.39",
    "prettier": "^3.3.3",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^2.0.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.celery.todo",
    "productName": "Celery Todo",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": ".",
        "filter": [
          "icon.png",
          "icon-16.png",
          "icon-32.png",
          "icon-64.png",
          "icon-128.png",
          "icon.ico"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    },
    "artifactName": "Celery-Todo-Setup-${version}.${ext}",
    "publish": {
      "provider": "github",
      "owner": "ouyangfeng2022",
      "repo": "celery-todo"
    }
  }
}
