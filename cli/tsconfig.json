{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "../dist-cli",
    "rootDir": "./src",
    "types": ["node"]
  },
  "include": ["./**/*.ts"],
  "exclude": [
    "./test/**",
    "./**/*.spec.ts",
    "./**/*.test.ts",
    "./vitest.config.ts"
  ]
}
